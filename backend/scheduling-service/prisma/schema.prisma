generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppointmentStatus {
  HOLD
  CONFIRMED
  CANCELLED
  EXPIRED
  COMPLETED
}

model Appointment {
  id                        String                  @id
  tenantId                  String
  roomId                    String
  startAt                   DateTime
  endAt                     DateTime
  status                    AppointmentStatus
  serviceId                 String
  amount                    Int
  currency                  String                  @default("BRL")
  responsibleProfessionalId String
  customerId                String?
  holdExpiresAt             DateTime?
  externalRef               String?
  paymentRef                String?
  paidAt                    DateTime?
  confirmedAt               DateTime?
  cancelledAt               DateTime?
  cancelledBy               String?
  cancelReason              String?
  completedAt               DateTime?
  metadata                  Json?
  version                   Int                     @default(0)
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @default(now())
  participants              AppointmentParticipant[]

  @@unique([tenantId, externalRef])
  @@index([tenantId, startAt])
  @@index([tenantId, roomId, startAt, endAt])
  @@index([tenantId, responsibleProfessionalId, startAt, endAt])
  @@index([tenantId, status, holdExpiresAt])
  @@map("appointments")
}

model AppointmentParticipant {
  appointmentId String
  professionalId String
  createdAt      DateTime    @default(now())
  appointment    Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@id([appointmentId, professionalId])
  @@index([professionalId])
  @@map("appointment_participants")
}

model OutboxEvent {
  id            String    @id
  tenantId      String
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  occurredAt    DateTime
  publishedAt   DateTime?
  correlationId String
  version       String    @default("1.0")
  createdAt     DateTime  @default(now())

  @@index([publishedAt])
  @@map("outbox_events")
}

model ProcessedEvent {
  eventId     String    @id
  tenantId    String
  eventType   String
  processedAt DateTime  @default(now())

  @@map("processed_events")
}
